// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---- OpenDock iNFT Token Cache ----
// Mirrors the on-chain state and caches 0G Storage metadata for fast serving.
model AgentToken {
  // On-chain identity
  tokenId      String   @id              // BigInt stored as string
  chainId      Int      @default(16602)  // 0G Galileo testnet

  // On-chain hashes (bytes32 hex strings)
  metadataHash String
  dataHash     String?                  // first IntelligentData entry

  // Cached ERC-721 metadata (populated once 0G Storage is accessible)
  name         String?
  description  String?
  image        String?                  // served URL, e.g. /api/image/<hash>
  imageHash    String?                  // 0G root hash of the raw image

  // 0G sync status
  metadataReady  Boolean  @default(false)

  // Ownership
  owner        String?                  // checksummed address

  // Rental / marketplace
  rentOrderId        String?            // active marketplace rent order ID
  rentPricePerSecond String?            // wei/second as decimal string
  rentMaxDuration    Int?               // seconds (0 = unlimited)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  computeWallets AgentComputeWallet[]
  conversations AgentConversation[]

  @@index([owner])
  @@index([metadataReady])
}

enum AgentConversationRole {
  user
  assistant
}

model AgentConversation {
  id              String   @id @default(cuid())
  tokenId         String
  userAddress     String
  title           String?
  providerAddress String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastMessageAt   DateTime @default(now())

  agentToken AgentToken @relation(fields: [tokenId], references: [tokenId], onDelete: Cascade)
  messages   AgentConversationMessage[]

  @@index([tokenId, userAddress, lastMessageAt])
  @@index([userAddress])
}

model AgentConversationMessage {
  id             String                @id @default(cuid())
  conversationId String
  sequence       Int
  role           AgentConversationRole
  content        String                @db.Text
  createdAt      DateTime              @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, sequence])
  @@index([conversationId, createdAt])
}

// Per-user settings (e.g. API keys for optional integrations).
model UserSetting {
  userAddress String @id  // checksummed/lowercased wallet address

  braveApiKey    String?  // Brave Search API key for web search tool
  telegramUserId String?  // Bound Telegram user ID (numeric string)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Per-user hosted compute wallet for an agent.
// Stores only derivation metadata; the private key is derived at runtime from
// the server root secret and never persisted in the database.
model AgentComputeWallet {
  id          Int      @id @default(autoincrement())
  tokenId     String
  userAddress String
  hdPath      String   @unique
  address     String   @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agentToken AgentToken @relation(fields: [tokenId], references: [tokenId], onDelete: Cascade)

  @@unique([tokenId, userAddress])
  @@index([userAddress])
}
